<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="memberManagerArea" prefHeight="720.0" prefWidth="1145.0" styleClass="main-bg" stylesheets="@/org/proptit/localchat/member.css" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.proptit.localchat.client.controller.MemberManagementController">
    <children>
        <VBox spacing="20.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="40.0">
            <children>
                <Label styleClass="header-title" text="Member Management" />

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <HBox alignment="CENTER_LEFT" maxWidth="400.0" styleClass="search-box" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="🔍" textFill="#8b92a5" />
                                <TextField fx:id="txtSearchPeople" promptText="Search people by username or nickname..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <Button fx:id="btnAddMember" mnemonicParsing="false" onAction="#onAddMemberClick" styleClass="btn-primary" text="⊕ Add Member" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="custom-scroll-pane" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="150.0">
            <content>
                <VBox fx:id="vboxMemberList" spacing="10.0" styleClass="member-list-container">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>