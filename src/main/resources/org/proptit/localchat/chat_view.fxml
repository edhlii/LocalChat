<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<?import javafx.scene.shape.Circle?>
<HBox prefHeight="720.0" prefWidth="1145.0" stylesheets="@chat.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.proptit.localchat.client.controller.ChatController">
    <children>

        <VBox prefWidth="280.0" styleClass="sidebar-container" HBox.hgrow="NEVER">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="55.0" prefWidth="278.0" styleClass="sidebar-header">
                    <children>
                        <VBox alignment="CENTER_LEFT" spacing="2.0">

                            <Label styleClass="workspace-name" text="LocalChat" />
                            <HBox alignment="CENTER_LEFT" spacing="5.0">
                                <Circle fill="#23A559" radius="4.0" />
                                <Label styleClass="status-text" text="Connected" />
                            </HBox>

                            <Label alignment="CENTER" prefHeight="60.0" prefWidth="260.0" styleClass="workspace-name" text="LocalChat" />

                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />
                        <Button minWidth="30.0" onAction="#onCreateGroupClick" style="-fx-background-color: #3A3B3C; -fx-text-fill: #E4E6EB; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 14px;" text="+" />

                    </children>
                    <padding>
                        <Insets left="20.0" right="20.0" />
                    </padding>
                </HBox>

                <VBox prefWidth="279.0" spacing="5.0" VBox.vgrow="NEVER">
                    <padding>
                        <Insets left="20.0" right="20.0" top="15.0" />
                    </padding>
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="section-title" text="ONLINE PEOPLE" textFill="#907171" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label styleClass="status-dot" text="●" textFill="#23A559" />
                    </HBox>
                    <ListView fx:id="lvOnlinePeople" prefHeight="130.0" styleClass="custom-list-view" />
                </VBox>

                <VBox prefHeight="241.0" prefWidth="278.0" spacing="5.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                    </padding>
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="section-title" text="CONVERSATIONS" />
                        <Region HBox.hgrow="ALWAYS" />
                    </HBox>

                    <HBox alignment="CENTER" spacing="0" style="-fx-background-color: #F0F2F5; -fx-background-radius: 8;">
                        <padding>
                            <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
                        </padding>
                        <children>
                            <Button fx:id="btnTabAll" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#onTabAllClick" style="-fx-background-color: #0084FF; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold;" text="All" />
                            <Button fx:id="btnTabGroups" maxWidth="Infinity" HBox.hgrow="ALWAYS" onAction="#onTabGroupsClick" style="-fx-background-color: transparent; -fx-text-fill: #65676B; -fx-background-radius: 6; -fx-font-weight: bold;" text="Groups" />
                        </children>
                    </HBox>
                    
<!--                    <ListView fx:id="lvChatList" styleClass="custom-list-view" VBox.vgrow="ALWAYS" />-->

               <HBox prefHeight="49.0" prefWidth="238.0">
                  <children>
                     <Label contentDisplay="BOTTOM" prefHeight="35.0" prefWidth="19.0" text="🔍" textFill="#8b92a5" />
                     <TextField fx:id="txtSearchPeopleChat" prefHeight="35.0" prefWidth="224.0" promptText="Search people by username/nickname" styleClass="search-field" />
                  </children>
               </HBox>
                    <ListView fx:id="lvChatList" prefHeight="270.0" prefWidth="238.0" styleClass="custom-list-view" VBox.vgrow="ALWAYS">
                  <padding>
                     <Insets bottom="100.0" />
                  </padding></ListView>
               <VBox.margin>
                  <Insets bottom="25.0" />
               </VBox.margin>

                </VBox>


            </children>
        </VBox>

        <BorderPane styleClass="chat-container" HBox.hgrow="ALWAYS">

            <top>
                <HBox alignment="CENTER_LEFT" prefHeight="56.0" prefWidth="865.0" spacing="15.0" styleClass="chat-header" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets left="25.0" right="25.0" />
                    </padding>

                    <Label fx:id="contactNameTopBar" prefHeight="27.0" prefWidth="163.0" styleClass="channel-title" text="Contact name..." />
                    <Region prefHeight="117.0" prefWidth="492.0" HBox.hgrow="ALWAYS" />

                    <Button fx:id="callButton" mnemonicParsing="false" onAction="#onCallButtonClick" prefHeight="33.0" prefWidth="106.0" styleClass="btn-call" text="Call" textFill="WHITE">
                        <graphic>
                            <SVGPath content="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" styleClass="icon-svg" />
                        </graphic>
                    </Button>

                    <Button fx:id="videoCallButton" mnemonicParsing="false" onAction="#onVideoCallButtonClick" prefHeight="33.0" prefWidth="113.0" styleClass="btn-video-call" text="Video" textFill="WHITE">
                        <graphic>
                            <SVGPath content="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z" fill="WHITE" styleClass="icon-svg" />
                        </graphic>
                    </Button>
                </HBox>
            </top>

            <center>
                <ScrollPane fx:id="scrollPane" fitToWidth="true" styleClass="chat-scroll-pane" BorderPane.alignment="CENTER">
                    <content>
                        <VBox fx:id="vboxMessage" spacing="20.0" styleClass="message-area">
                            <padding>
                                <Insets bottom="20.0" left="30.0" right="30.0" top="30.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>

            <bottom>
                <VBox styleClass="chat-input-container" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="20.0" left="25.0" right="25.0" top="10.0" />
                    </padding>
                    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="chat-input-box">
                        <padding>
                            <Insets bottom="8.0" left="15.0" right="8.0" top="8.0" />
                        </padding>

                        <Button contentDisplay="GRAPHIC_ONLY" mnemonicParsing="false" onAction="#onFileButtonClick" styleClass="btn-icon">
                            <graphic>
                                <SVGPath content="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5V5c0-2.21-1.79-4-4-4S7 2.79 7 5v12.5c0 3.04 2.46 5.5 5.5 5.5s5.5-2.46 5.5-5.5V6h-1.5z" styleClass="icon-svg" />
                            </graphic>
                        </Button>

                        <TextField fx:id="messageInput" promptText="Type a message..." styleClass="message-text-field" HBox.hgrow="ALWAYS" />

                        <Button fx:id="sendMessageButton" contentDisplay="GRAPHIC_ONLY" mnemonicParsing="false" onAction="#onSendButtonClick" styleClass="btn-send">
                            <graphic>
                                <SVGPath content="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" styleClass="icon-svg-send" />
                            </graphic>
                        </Button>
                    </HBox>
                </VBox>
            </bottom>

        </BorderPane>
    </children>
</HBox>
