<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.proptit.localchat.client.controller.MainWindowController">
    <children>
        <VBox alignment="TOP_CENTER" maxWidth="135.0" minWidth="84.0" prefHeight="720.0" prefWidth="90.0" spacing="20.0" style="-fx-background-color: #0d1a5f;">
            <children>
                <Button fx:id="btnNavChat" contentDisplay="CENTER" mnemonicParsing="false" onAction="#onNavChatClick" prefHeight="60.0" prefWidth="60.0" text="💬">
                    <font>
                        <Font size="23.0" />
                    </font>
                </Button>
                <Button fx:id="btnNavMembers" contentDisplay="CENTER" mnemonicParsing="false" onAction="#onNavMembersClick" prefHeight="60.0" prefWidth="60.0" text="👥">
                    <font>
                        <Font size="23.0" />
                    </font>
                </Button>
            </children>
            <padding>
                <Insets top="20.0" />
            </padding>
        </VBox>

        <StackPane HBox.hgrow="ALWAYS">
            <children>

                <AnchorPane fx:id="memberManagerArea" prefWidth="1145.0" style="-fx-background-color: #6699FF;">
                    <children>
                        <Label layoutX="427.0" layoutY="23.0" text="Member Management" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" layoutX="38.0" layoutY="75.0" prefHeight="550.0" prefWidth="1070.0" AnchorPane.bottomAnchor="95.0" AnchorPane.leftAnchor="38.0" AnchorPane.rightAnchor="37.0" AnchorPane.topAnchor="75.0">
                            <content>
                                <VBox fx:id="vboxMemberList" spacing="5.0" style="-fx-padding: 10;" />
                            </content>
                        </ScrollPane>
                        <Button fx:id="btnAddMember" mnemonicParsing="false" prefHeight="60.0" prefWidth="60.0" style="-fx-background-radius: 100; -fx-background-color: white;" text="➕" AnchorPane.bottomAnchor="20.0" AnchorPane.rightAnchor="30.0">
                            <font>
                                <Font size="24.0" />
                            </font></Button>
                    </children>
                </AnchorPane>
                <SplitPane fx:id="chatAreaContainer" dividerPositions="0.3" prefHeight="720.0" prefWidth="1145.0" style="-fx-background-color: transparent;">
                    <items>
                        <AnchorPane fx:id="sidebarArea" minWidth="250.0" prefWidth="300.0" style="-fx-background-color: #f4f4f4;">
                            <children>
                                <ListView fx:id="lvChatList" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                            </children>
                        </AnchorPane>

                        <AnchorPane style="-fx-background-color: white;">
                            <children>
                                <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <center>
                                        <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                                            <content>
                                                <VBox fx:id="vboxMessage" spacing="10.0" style="-fx-background-color: transparent;">
                                                    <padding>
                                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                                    </padding></VBox>
                                            </content>
                                        </ScrollPane>
                                    </center>
                                    <bottom>
                                        <HBox alignment="CENTER" prefHeight="80.0" spacing="10.0" style="-fx-padding: 10;">
                                            <children>
                                                <TextArea fx:id="messageInput" prefHeight="29.0" prefWidth="537.0" promptText="Type a message..." HBox.hgrow="ALWAYS" />
                                                <Button mnemonicParsing="false" onAction="#onFileButtonClick" prefHeight="60.0" prefWidth="70.0" text="File" />
                                                <Button fx:id="sendMessageButton" mnemonicParsing="false" onAction="#onSendButtonClick" prefHeight="60.0" prefWidth="70.0" text="Send" />
                                                <Button fx:id="sendMessageAllButton" mnemonicParsing="false" onAction="#onSendButtonClick" prefHeight="60.0" prefWidth="70.0" text="Send All" />
                                            </children>
                                        </HBox>
                                    </bottom>
                                </BorderPane>
                            </children>
                        </AnchorPane>
                    </items>
                </SplitPane>
            </children>
        </StackPane>
    </children>
</HBox>
