<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<HBox prefHeight="720.0" prefWidth="1280.0" stylesheets="@/org/proptit/localchat/main.css" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.proptit.localchat.client.controller.MainWindowController">
    <children>
        <VBox alignment="TOP_CENTER" maxWidth="80.0" minWidth="80.0" prefHeight="720.0" prefWidth="80.0" spacing="25.0" styleClass="nav-sidebar">
            <children>
                <Region prefHeight="10.0" />

                <Button fx:id="btnNavChat" contentDisplay="GRAPHIC_ONLY" mnemonicParsing="false" onAction="#onNavChatClick" styleClass="nav-button">
                    <graphic>
                        <SVGPath styleClass="nav-icon" content="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z" />
                    </graphic>
                </Button>

                <Button fx:id="btnNavMembers" contentDisplay="GRAPHIC_ONLY" mnemonicParsing="false" onAction="#onNavMembersClick" styleClass="nav-button">
                    <graphic>
                        <SVGPath styleClass="nav-icon" content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" />
                    </graphic>
                </Button>

                <Region VBox.vgrow="ALWAYS" />

                <Button fx:id="btnChangePassword" contentDisplay="GRAPHIC_ONLY" mnemonicParsing="false" onAction="#onChangePasswordAction" styleClass="nav-button">
                    <graphic>
                        <SVGPath styleClass="nav-icon" content="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.06-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.73,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.06,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.43-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.49-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" />
                    </graphic>
                </Button>
            </children>
            <padding>
                <Insets bottom="20.0" top="20.0" />
            </padding>
        </VBox>

        <StackPane HBox.hgrow="ALWAYS" styleClass="content-area">
            <children>
                <fx:include fx:id="chatArea" source="chat_view.fxml" />
                <fx:include fx:id="memberManagerArea" source="member_management_view.fxml" />
            </children>
        </StackPane>
    </children>
</HBox>