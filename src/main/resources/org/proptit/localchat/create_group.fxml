<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" prefHeight="450.0" prefWidth="350.0" spacing="15.0"
      stylesheets="@create_group.css" styleClass="root"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.proptit.localchat.client.controller.CreateGroupController">

    <children>
        <Label text="TẠO NHÓM CHAT" styleClass="header-label" />

        <VBox spacing="5.0">
            <Label text="TÊN NHÓM" styleClass="field-label" />
            <TextField fx:id="txtGroupName" promptText="Nhập tên nhóm..." styleClass="text-field" />
        </VBox>

        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
            <Label text="CHỌN THÀNH VIÊN" styleClass="field-label" />

            <ListView fx:id="lvMembers" VBox.vgrow="ALWAYS" styleClass="list-view" />
        </VBox>

        <Label fx:id="lblError" textFill="#ff5252" wrapText="true" />

        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#onCancelClick" prefWidth="100.0" text="Cancel" styleClass="btn-secondary" />
            <Button fx:id="btnCreate" mnemonicParsing="false" onAction="#onCreateClick" prefWidth="120.0" text="Save" styleClass="btn-primary" />
        </HBox>
    </children>

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>